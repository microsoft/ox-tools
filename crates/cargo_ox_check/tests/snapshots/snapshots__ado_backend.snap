=== .pipelines/ox-check/steps/setup.yml ===
# Copyright (c) Microsoft Corporation.
# Licensed under the MIT License.
# Owned by cargo-ox-check; edit via `cargo ox-check update`.
steps:
  - bash: echo "##vso[task.setvariable variable=ox_check_rustc_version]$(rustc --version | awk '{print $2}')"
    displayName: ox-check setup (capture rustc version)
  - task: Cache@2
    inputs:
      # Same key shape as the GitHub side: OS + arch + rustc version +
      # lockfile hashes + catalog hash. Including arch keeps any
      # future ARM pool an adopter adds from colliding with x86_64 on
      # the same OS namespace.
      key: 'ox-check-v1 | "$(Agent.OS)" | "$(Agent.OSArchitecture)" | rust$(ox_check_rustc_version) | Cargo.lock | .cargo/config.toml | rust-toolchain.toml | justfiles/ox-check/tool-minimums.txt | justfiles/ox-check/versions.just'
      restoreKeys: |
        ox-check-v1 | "$(Agent.OS)" | "$(Agent.OSArchitecture)" | rust$(ox_check_rustc_version)
        ox-check-v1 | "$(Agent.OS)" | "$(Agent.OSArchitecture)"
      path: |
        $(HOME)/.cargo/registry/cache/
        $(HOME)/.cargo/registry/index/
        $(HOME)/.cargo/bin/
        target/
    displayName: ox-check setup (cache cargo home and target)

  # System dependencies for catalog source builds. See the GitHub
  # composite setup-action.yml for the rationale — same pattern.
  # Detect the distro's package manager so this works on Ubuntu agents
  # (apt-get) and Azure Linux 3 agents (tdnf, common on 1ESPT) alike.
  - bash: |
      set -euo pipefail
      if command -v tdnf >/dev/null 2>&1; then
        sudo tdnf install -y clang-devel
      elif command -v dnf >/dev/null 2>&1; then
        sudo dnf install -y clang-devel
      elif command -v apt-get >/dev/null 2>&1; then
        sudo apt-get update && sudo apt-get install -y libclang-dev
      else
        echo "No supported package manager found (tdnf/dnf/apt-get)" >&2
        exit 1
      fi
    condition: eq(variables['Agent.OS'], 'Linux')
    displayName: ox-check setup (install libclang on Linux)

  - bash: rustup component add rustfmt clippy
    displayName: ox-check setup (ensure rustfmt + clippy components)

  - bash: |
      if ! command -v just >/dev/null 2>&1 ; then
        cargo install --locked just
      fi
    displayName: ox-check setup (install just)

  # Install the pinned nightly toolchains needed by udeps, miri,
  # careful, and check-external-types. The pins live in
  # justfiles/ox-check/versions.just as `rust_nightly` and
  # `rust_nightly_external_types`; we extract them here so there is
  # exactly one source of truth shared with recipe interpolation.
  - bash: |
      set -euo pipefail
      rust_nightly=$(just --evaluate rust_nightly)
      rust_nightly_external_types=$(just --evaluate rust_nightly_external_types)
      echo "ox-check: pinned nightly toolchains: $rust_nightly, $rust_nightly_external_types"
      # --component rustfmt because ox-check-fmt uses nightly rustfmt
      # for unstable_features (imports_granularity etc.).
      rustup toolchain install "$rust_nightly" --profile minimal --component rustfmt --no-self-update
      if [ "$rust_nightly" != "$rust_nightly_external_types" ]; then
        rustup toolchain install "$rust_nightly_external_types" --profile minimal --no-self-update
      fi
    displayName: ox-check setup (install pinned nightly toolchains)

  - bash: |
      just ox-check-tools-install
    # ox-check-tools-install exits non-zero if any per-tool install
    # failed (e.g. cargo-mutants doesn't build on aarch64-pc-windows-
    # msvc due to an upstream winapi incompatibility). We don't fail
    # the whole job here — recipes that actually USE a missing tool
    # will fail cleanly via _ox-check-require at recipe-run time.
    continueOnError: true
    displayName: ox-check setup (install catalog tools)

