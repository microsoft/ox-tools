=== .delta.toml ===
# >>> ox-check-managed: ox-check-delta
[delta]
# Include the workspace root files that should invalidate every member's
# impact analysis when changed (lockfile, root manifest, toolchain).
root-files = [
    "Cargo.lock",
    "Cargo.toml",
    "rust-toolchain.toml",
]
# <<< ox-check-managed: ox-check-delta

=== .github/actions/ox-check-impact/action.yml ===
# Copyright (c) Microsoft Corporation.
# Licensed under the MIT License.
# Owned by cargo-ox-check; edit via `cargo ox-check update`.
name: ox-check-impact
description: |
  Compute the cargo-delta impact set for this PR and emit two outputs:
    excludes - comma-separated list of crates not touched by the diff
    skip     - "true" iff no ox-check-relevant files changed at all
outputs:
  excludes:
    description: Comma-separated package excludes
    value: ${{ steps.compute.outputs.excludes }}
  skip:
    description: Whether all ox-check groups should be skipped this run
    value: ${{ steps.compute.outputs.skip }}
runs:
  using: composite
  steps:
    - name: Install cargo-delta
      shell: bash
      run: cargo install --locked cargo-delta
    - id: compute
      name: Compute impact
      shell: bash
      run: |
        base="${BASE_REF:-${GITHUB_BASE_REF:-origin/main}}"
        result="$(cargo delta impact --base "$base" --format json || echo '{}')"
        excludes="$(printf '%s' "$result" | jq -r '.excludes // [] | join(",")')"
        skip="$(printf '%s' "$result" | jq -r '.skip // false')"
        echo "excludes=$excludes" >> "$GITHUB_OUTPUT"
        echo "skip=$skip" >> "$GITHUB_OUTPUT"

=== .github/actions/ox-check-nightly-advisories/action.yml ===
# Copyright (c) Microsoft Corporation.
# Licensed under the MIT License.
# Owned by cargo-ox-check; edit via `cargo ox-check update`.
# The token nightly-advisories is substituted by cargo-ox-check at emit time with
# the concrete check-group name (pr-fast, pr-test, nightly-runtime, ...).
name: ox-check-nightly-advisories
description: Run the nightly-advisories check group.
inputs:
  excludes:
    description: Comma-separated package excludes from the impact job.
    default: ""
    required: false
  skip:
    description: If "true", skip this group entirely.
    default: "false"
    required: false
runs:
  using: composite
  steps:
    - if: inputs.skip != 'true'
      uses: ./.github/actions/ox-check-setup
    - if: inputs.skip != 'true'
      name: Run just ox-check-nightly-advisories
      shell: bash
      env:
        OX_CHECK_EXCLUDES: ${{ inputs.excludes }}
      run: just ox-check-nightly-advisories

