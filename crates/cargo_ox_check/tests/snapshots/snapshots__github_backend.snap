name: ox-check-nightly

on:
  schedule:
    - cron: "0 7 * * *"
  workflow_dispatch: {}

permissions:
  contents: read

jobs:
  ox-check-nightly:
    uses: ./.github/workflows/ox-check-nightly-impl.yml
    permissions:
      contents: read
    secrets: inherit

=== .github/workflows/ox-check-pr-impl.yml ===
# Copyright (c) Microsoft Corporation.
# Licensed under the MIT License.
# Owned by cargo-ox-check; edit via `cargo ox-check update`.
name: ox-check-pr-impl

on:
  workflow_call:
    inputs:
      test_os:
        description: Comma-separated OS list for pr-test matrix (linux, windows, macos).
        type: string
        default: linux,windows
      linux_runner:
        description: Runner label for Linux jobs.
        type: string
        default: ubuntu-latest
      windows_runner:
        description: Runner label for Windows jobs.
        type: string
        default: windows-latest
      macos_runner:
        description: Runner label for macOS jobs.
        type: string
        default: macos-latest
    secrets:
      CODECOV_TOKEN:
        description: |
          Codecov upload token. Optional for public repos that have OIDC
          configured at Codecov; required for private repos.
        required: false

jobs:
  impact:
    runs-on: ${{ inputs.linux_runner }}
    outputs:
      excludes: ${{ steps.delta.outputs.excludes }}
      skip: ${{ steps.delta.outputs.skip }}
    steps:
      - uses: actions/checkout@v4
        with:
          fetch-depth: 0
      - id: delta
        uses: ./.github/actions/ox-check-impact

  pr-fast:
    needs: impact
    runs-on: ${{ inputs.linux_runner }}
    steps:
      - uses: actions/checkout@v4
      - uses: ./.github/actions/ox-check-pr-fast
        with:
          excludes: ${{ needs.impact.outputs.excludes }}
          skip: ${{ needs.impact.outputs.skip }}
        env:
          PR_TITLE: ${{ github.event.pull_request.title }}

  pr-test:
    needs: impact
    strategy:
      fail-fast: false
      matrix:
        os: ${{ fromJSON(format('[{0}]', inputs.test_os)) }}
    runs-on: ${{ matrix.os == 'linux' && inputs.linux_runner
      || matrix.os == 'windows' && inputs.windows_runner
      || inputs.macos_runner }}
    steps:
      - uses: actions/checkout@v4
      - uses: ./.github/actions/ox-check-pr-test
        with:
          excludes: ${{ needs.impact.outputs.excludes }}
          skip: ${{ needs.impact.outputs.skip }}
      - name: Upload coverage to Codecov
        if: matrix.os == 'linux' && needs.impact.outputs.skip != 'true'
        uses: codecov/codecov-action@v5
        with:
          files: target/coverage/lcov.info
          token: ${{ secrets.CODECOV_TOKEN }}
          fail_ci_if_error: false

  pr-mutants:
    needs: impact
    runs-on: ${{ inputs.linux_runner }}
    steps:
      - uses: actions/checkout@v4
        with:
          fetch-depth: 0
      - uses: ./.github/actions/ox-check-pr-mutants
        with:
          excludes: ${{ needs.impact.outputs.excludes }}
          skip: ${{ needs.impact.outputs.skip }}
        env:
          BASE_REF: ${{ github.event.pull_request.base.sha }}

=== .github/workflows/ox-check-pr.yml ===
# Copyright (c) Microsoft Corporation.
# Licensed under the MIT License.
# Owned by cargo-ox-check; edit via `cargo ox-check update`.
name: ox-check-pr

on:
  pull_request: {}
  merge_group: {}

permissions:
  contents: read

concurrency:
  group: ox-check-pr-${{ github.head_ref || github.ref }}
  cancel-in-progress: true

jobs:
  ox-check-pr:
    uses: ./.github/workflows/ox-check-pr-impl.yml
    permissions:
      contents: read
      pull-requests: read
    secrets: inherit

=== Cargo.toml ===
[workspace]
resolver = "2"
members = ["crates/*"]

# >>> ox-check-managed: ox-check-workspace-lints
[workspace.lints]
# Catalog of opinionated lints, in dotted-key form so users can extend the
# same scope (`[workspace.lints]` or `[lints]`) outside the sentinels.
# The host-specific table header (`[workspace.lints]` or `[lints]`) is
# prepended by cargo-ox-check based on whether the manifest is a workspace
# root or a single-crate Cargo.toml.

# --- rust ------------------------------------------------------------------
rust.ambiguous_negative_literals = "warn"
rust.missing_debug_implementations = "warn"
rust.missing_docs = "warn"
rust.redundant_imports = "warn"
rust.redundant_lifetimes = "warn"
rust.trivial_numeric_casts = "warn"
rust.unsafe_op_in_unsafe_fn = "warn"
rust.unused_lifetimes = "warn"

# --- rustdoc ---------------------------------------------------------------
rustdoc.missing_crate_level_docs = "warn"
rustdoc.unescaped_backticks = "warn"

# --- clippy: category gates (priority -1 so per-lint allows can override) --
clippy.cargo = { level = "warn", priority = -1 }
clippy.complexity = { level = "warn", priority = -1 }
clippy.correctness = { level = "warn", priority = -1 }
clippy.nursery = { level = "warn", priority = -1 }
clippy.pedantic = { level = "warn", priority = -1 }
clippy.perf = { level = "warn", priority = -1 }
clippy.style = { level = "warn", priority = -1 }
clippy.suspicious = { level = "warn", priority = -1 }

# --- clippy: opinionated additions -----------------------------------------
clippy.allow_attributes = "warn"
clippy.allow_attributes_without_reason = "warn"
clippy.clone_on_ref_ptr = "warn"
clippy.disallowed_script_idents = "warn"
clippy.map_err_ignore = "warn"
clippy.panic = "warn"
clippy.undocumented_unsafe_blocks = "warn"
clippy.unnecessary_safety_comment = "warn"
clippy.unwrap_used = "warn"

# --- clippy: opinionated suppressions of category-enabled lints ------------
clippy.option_if_let_else = "allow"
clippy.missing_const_for_fn = "allow"
clippy.multiple_crate_versions = "allow"
clippy.significant_drop_tightening = "allow"
clippy.wildcard_imports = "allow"
# <<< ox-check-managed: ox-check-workspace-lints

