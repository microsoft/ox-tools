=== .github/actions/ox-check-setup/action.yml ===
# Copyright (c) Microsoft Corporation.
# Licensed under the MIT License.
# Owned by cargo-ox-check; edit via `cargo ox-check update`.
name: ox-check-setup
description: Install `just` and the catalog of cargo tools for ox-check check groups.
runs:
  using: composite
  steps:
    - name: Install just
      shell: bash
      run: |
        if ! command -v just >/dev/null 2>&1 ; then
          cargo install --locked just
        fi
    - name: Install catalog tools
      shell: bash
      run: just ox-check-tools-install

=== .github/workflows/ox-check-nightly-impl.yml ===
# Copyright (c) Microsoft Corporation.
# Licensed under the MIT License.
# Owned by cargo-ox-check; edit via `cargo ox-check update`.
name: ox-check-nightly-impl

on:
  workflow_call:
    inputs:
      test_os:
        description: Comma-separated OS list for nightly-test matrix (linux, windows, macos).
        type: string
        default: linux,windows
      linux_runner:
        description: Runner label for Linux jobs.
        type: string
        default: ubuntu-latest
      windows_runner:
        description: Runner label for Windows jobs.
        type: string
        default: windows-latest
      macos_runner:
        description: Runner label for macOS jobs.
        type: string
        default: macos-latest
    secrets:
      CODECOV_TOKEN:
        description: |
          Codecov upload token. Optional for public repos that have OIDC
          configured at Codecov; required for private repos.
        required: false

jobs:
  nightly-test:
    strategy:
      fail-fast: false
      matrix:
        os: ${{ fromJSON(format('[{0}]', inputs.test_os)) }}
    runs-on: ${{ matrix.os == 'linux' && inputs.linux_runner
      || matrix.os == 'windows' && inputs.windows_runner
      || inputs.macos_runner }}
    steps:
      - uses: actions/checkout@v4
      - uses: ./.github/actions/ox-check-nightly-test
      - name: Upload coverage to Codecov
        if: matrix.os == 'linux'
        uses: codecov/codecov-action@v5
        with:
          files: target/coverage/lcov.info
          token: ${{ secrets.CODECOV_TOKEN }}
          flags: nightly
          fail_ci_if_error: false

  nightly-advisories:
    runs-on: ${{ inputs.linux_runner }}
    steps:
      - uses: actions/checkout@v4
      - uses: ./.github/actions/ox-check-nightly-advisories

  nightly-runtime:
    runs-on: ${{ inputs.linux_runner }}
    steps:
      - uses: actions/checkout@v4
      - uses: ./.github/actions/ox-check-nightly-runtime

  nightly-exhaustive:
    runs-on: ${{ inputs.linux_runner }}
    steps:
      - uses: actions/checkout@v4
      - uses: ./.github/actions/ox-check-nightly-exhaustive

