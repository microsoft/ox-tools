=== deny.toml ===
# >>> ox-check-managed: ox-check-deny
[advisories]
yanked = "deny"
unmaintained = "warn"

[licenses]
allow = [
    "MIT",
    "Apache-2.0",
    "Apache-2.0 WITH LLVM-exception",
    "BSD-2-Clause",
    "BSD-3-Clause",
    "ISC",
    "MPL-2.0",
    "Unicode-DFS-2016",
    "Unicode-3.0",
    "Zlib",
]
confidence-threshold = 0.93

[bans]
multiple-versions = "warn"
wildcards = "deny"

[sources]
unknown-registry = "deny"
unknown-git = "deny"
# <<< ox-check-managed: ox-check-deny

=== justfiles/ox-check/checks.just ===
# Copyright (c) Microsoft Corporation.
# Licensed under the MIT License.
# Owned by cargo-ox-check; edit via `cargo ox-check update`.
# See ../../docs/design/checks.md for the catalog and rationale.
#
# Each check belongs to one of four buckets, which determines how it
# interprets the impact env vars emitted by the cargo-delta impact step
# in CI:
#
#   - "modified": only run when at least one package's source files
#     changed in the diff. The check's underlying tool is workspace-wide
#     or directory-scoped (cargo fmt --all, cargo heather, cargo
#     spellcheck), so it doesn't take --package; we short-circuit on
#     the OX_CHECK_INCLUDE_MODIFIED == "--skip" sentinel.
#
#   - "affected": run on the affected set (modified ∪ reverse-deps
#     within the workspace). The check's underlying tool takes
#     --package; we splice OX_CHECK_INCLUDE_AFFECTED into the cargo
#     invocation, defaulting to --workspace for local invocations where
#     no env var is set.
#
#   - "required": run on the required set (affected ∪ workspace-internal
#     transitive deps). Same splice/default pattern as affected, but
#     keyed on OX_CHECK_INCLUDE_REQUIRED. Used for checks whose tool
#     resolves through the dep graph (cargo doc → intra-doc links;
#     cargo hack → feature powerset; cargo udeps → unused-deps).
#
#   - "unscoped": always run, no env var reference. External-input
#     checks (deny, audit, aprz) and PR-context checks (pr-title) live
#     here. Nightly-exhaustive recipes (mutants-full) are also unscoped
#     by design.
#
# Local invocation (no impact wiring): all three env vars are unset;
# modified recipes run unconditionally and affected/required recipes
# default to --workspace.
#
# Every recipe whose body uses multi-line conditionals or env-var
# splicing is annotated with [script("pwsh")]. pwsh is preinstalled on
# Windows (since Windows 10), on GH/ADO hosted Linux + Windows
# runners, and installable on macOS via Homebrew or the upstream
# installer. We chose pwsh over bash because just's shebang dispatch
# requires `cygpath` on Windows (only on PATH from inside Git Bash),
# while [script("pwsh")] works from plain PowerShell with no PATH
# augmentation. The existing _ox-check-require pwsh precedent already
# established pwsh as a tools-floor requirement.
#
# Single-command recipes (cargo deny check, cargo audit) are plain
# just recipes that inherit the adopter's default shell — they're
# shell-agnostic.
#
# Note: [script(...)] requires `set unstable`. The adopter's root
# justfile must declare it (typically as a top-level line). ox-check's
# mod.just does NOT redeclare it, to avoid conflicting with adopters
# who already have it.

# === pr-fast members ====================================================

# Modified tier. cargo-fmt is a rustup component; if cargo is on PATH,
# fmt is too, so no require is needed.
[script("pwsh")]
ox-check-fmt:
    $ErrorActionPreference = 'Stop'
    if ($env:OX_CHECK_INCLUDE_MODIFIED -eq '--skip') {
        Write-Host 'ox-check-fmt: no modified packages; skipping'
        exit 0
    }
    cargo fmt --all --check
    if ($LASTEXITCODE -ne 0) { exit $LASTEXITCODE }

# Affected tier. Per project policy, clippy runs on the affected set
# rather than the modified set: a change in a crate can introduce a
# clippy issue in a dependent crate (e.g., trait-bound or
# obviously-truthy-condition lints that key off the changed type), so
# we want downstream rev-deps to lint as well. cargo-clippy is a
# rustup component; same reasoning as fmt for the require.
[script("pwsh")]
ox-check-clippy:
    $ErrorActionPreference = 'Stop'
    if ($env:OX_CHECK_INCLUDE_AFFECTED -eq '--skip') {
        Write-Host 'ox-check-clippy: no affected packages; skipping'
        exit 0
    }
    $pkg = @(if ($env:OX_CHECK_INCLUDE_AFFECTED) { -split $env:OX_CHECK_INCLUDE_AFFECTED } else { '--workspace' })
    & cargo clippy @pkg --all-targets --all-features --locked "--" '-D' 'warnings'
    if ($LASTEXITCODE -ne 0) { exit $LASTEXITCODE }

# Modified tier.
[script("pwsh")]
ox-check-cargo-sort: (_ox-check-require "cargo-sort")
    $ErrorActionPreference = 'Stop'
    if ($env:OX_CHECK_INCLUDE_MODIFIED -eq '--skip') {
        Write-Host 'ox-check-cargo-sort: no modified packages; skipping'
        exit 0
    }
    cargo sort --workspace --check
    if ($LASTEXITCODE -ne 0) { exit $LASTEXITCODE }

# Modified tier.
[script("pwsh")]
ox-check-license-headers: (_ox-check-require "cargo-heather")
    $ErrorActionPreference = 'Stop'
    if ($env:OX_CHECK_INCLUDE_MODIFIED -eq '--skip') {
        Write-Host 'ox-check-license-headers: no modified packages; skipping'
        exit 0
    }
    cargo heather
    if ($LASTEXITCODE -ne 0) { exit $LASTEXITCODE }

# Modified tier.
[script("pwsh")]
ox-check-ensure-no-cyclic-deps: (_ox-check-require "cargo-ensure-no-cyclic-deps")
    $ErrorActionPreference = 'Stop'
    if ($env:OX_CHECK_INCLUDE_MODIFIED -eq '--skip') {
        Write-Host 'ox-check-ensure-no-cyclic-deps: no modified packages; skipping'
        exit 0
    }
    cargo ensure-no-cyclic-deps
    if ($LASTEXITCODE -ne 0) { exit $LASTEXITCODE }

# Modified tier.
[script("pwsh")]
ox-check-ensure-no-default-features: (_ox-check-require "cargo-ensure-no-default-features")
    $ErrorActionPreference = 'Stop'
    if ($env:OX_CHECK_INCLUDE_MODIFIED -eq '--skip') {
        Write-Host 'ox-check-ensure-no-default-features: no modified packages; skipping'
        exit 0
    }
    cargo ensure-no-default-features
    if ($LASTEXITCODE -ne 0) { exit $LASTEXITCODE }

# Required tier. cargo doc resolves intra-doc links through the dep
# graph, so a dep changing its public API can break doc-build in a
# crate that wasn't itself modified.
[script("pwsh")]
ox-check-doc-build:
    $ErrorActionPreference = 'Stop'
    if ($env:OX_CHECK_INCLUDE_REQUIRED -eq '--skip') {
        Write-Host 'ox-check-doc-build: no required packages; skipping'
        exit 0
    }
    $pkg = @(if ($env:OX_CHECK_INCLUDE_REQUIRED) { -split $env:OX_CHECK_INCLUDE_REQUIRED } else { '--workspace' })
    $env:RUSTDOCFLAGS = '-D warnings'
    & cargo doc @pkg --all-features --no-deps
    if ($LASTEXITCODE -ne 0) { exit $LASTEXITCODE }

# Modified tier.
[script("pwsh")]
ox-check-readme-check: (_ox-check-require "cargo-doc2readme")
    $ErrorActionPreference = 'Stop'
    if ($env:OX_CHECK_INCLUDE_MODIFIED -eq '--skip') {
        Write-Host 'ox-check-readme-check: no modified packages; skipping'
        exit 0
    }
    cargo doc2readme --check --workspace
    if ($LASTEXITCODE -ne 0) { exit $LASTEXITCODE }

# Modified tier.
#
# cargo-spellcheck reads a Hunspell-compatible dictionary file at the
# path configured in spellcheck.toml (typically `extra_dictionaries =
# ["target/spelling.dic"]`). The convention used by the surveyed
# Microsoft Rust repos is to keep the *source* word list in a
# human-edited `.spelling` file at the repo root and preprocess it
# into the .dic format at check time (Hunspell .dic requires:
# alphabetical sort, blank/numeric lines removed, line-count header).
# If `.spelling` is present, we generate `target/spelling.dic` from it
# automatically; otherwise we run cargo-spellcheck against whatever
# the repo has already set up.
[script("pwsh")]
ox-check-spellcheck: (_ox-check-require "cargo-spellcheck")
    $ErrorActionPreference = 'Stop'
    if ($env:OX_CHECK_INCLUDE_MODIFIED -eq '--skip') {
        Write-Host 'ox-check-spellcheck: no modified packages; skipping'
        exit 0
    }
    if (Test-Path '.spelling') {
        $output_file = 'target/spelling.dic'
        $lines = Get-Content '.spelling' | Sort-Object
        $filtered_lines = $lines | Where-Object { $_ -notmatch '^\d+$' -and $_ -ne '' }
        $line_count = $filtered_lines.Count
        [System.IO.Directory]::CreateDirectory([System.IO.Path]::GetDirectoryName($output_file)) | Out-Null
        @($line_count) + $filtered_lines | Set-Content $output_file
    }
    # Pass --cfg explicitly when a spellcheck.toml exists at repo root,
    # otherwise cargo-spellcheck falls back to its built-in defaults and
    # ignores user-curated dictionaries (`extra_dictionaries`, custom
    # hunspell langs, etc.).
    if (Test-Path 'spellcheck.toml') {
        cargo spellcheck --cfg spellcheck.toml check --code 1
    } else {
        cargo spellcheck check --code 1
    }
    if ($LASTEXITCODE -ne 0) { exit $LASTEXITCODE }

# Unscoped (PR title is not source-related).
[script("pwsh")]
ox-check-pr-title: (_ox-check-require "pwsh")
    $title = $env:PR_TITLE
    if (-not $title) { $title = git log -1 --pretty=%s HEAD }
    if ($title -notmatch '^(feat|fix|chore|docs|refactor|test|build|ci|perf|revert)(\([^)]+\))?!?: .+') {
        Write-Error "PR title '$title' does not match Conventional Commits"
        exit 1
    }

# Unscoped (consults external advisory DB; reads Cargo.lock, not
# workspace members). Single command — inherits adopter's default shell.
ox-check-deny: (_ox-check-require "cargo-deny")
    cargo deny check

# Unscoped (consults external advisory DB; reads Cargo.lock).
ox-check-audit: (_ox-check-require "cargo-audit")
    cargo audit

# Required tier. cargo-udeps detects unused dependencies by resolving
# the full crate graph and seeing which deps are referenced; that's
# precisely what the required tier is for. Depends on the floating
# nightly toolchain.
[script("pwsh")]
ox-check-udeps: (_ox-check-require "cargo-udeps")
    $ErrorActionPreference = 'Stop'
    if ($env:OX_CHECK_INCLUDE_REQUIRED -eq '--skip') {
        Write-Host 'ox-check-udeps: no required packages; skipping'
        exit 0
    }
    $pkg = @(if ($env:OX_CHECK_INCLUDE_REQUIRED) { -split $env:OX_CHECK_INCLUDE_REQUIRED } else { '--workspace' })
    & cargo '+nightly' udeps @pkg --all-targets --all-features
    if ($LASTEXITCODE -ne 0) { exit $LASTEXITCODE }

# Affected tier (compares published API of changed crates against the
# baseline; only changed crates' surface is at risk).
[script("pwsh")]
ox-check-semver-check: (_ox-check-require "cargo-semver-checks")
    $ErrorActionPreference = 'Stop'
    if ($env:OX_CHECK_INCLUDE_AFFECTED -eq '--skip') {
        Write-Host 'ox-check-semver-check: no affected packages; skipping'
        exit 0
    }
    $pkg = @(if ($env:OX_CHECK_INCLUDE_AFFECTED) { -split $env:OX_CHECK_INCLUDE_AFFECTED } else { '--workspace' })
    & cargo semver-checks @pkg
    if ($LASTEXITCODE -ne 0) { exit $LASTEXITCODE }

# Affected tier (lints public API of changed crates and rev-deps).
[script("pwsh")]
ox-check-external-types: (_ox-check-require "cargo-check-external-types")
    $ErrorActionPreference = 'Stop'
    if ($env:OX_CHECK_INCLUDE_AFFECTED -eq '--skip') {
        Write-Host 'ox-check-external-types: no affected packages; skipping'
        exit 0
    }
    $pkg = @(if ($env:OX_CHECK_INCLUDE_AFFECTED) { -split $env:OX_CHECK_INCLUDE_AFFECTED } else { '--workspace' })
    & cargo check-external-types @pkg
    if ($LASTEXITCODE -ne 0) { exit $LASTEXITCODE }

# Unscoped (consults external risk DB).
ox-check-aprz: (_ox-check-require "cargo-aprz")
    cargo aprz check

# === pr-test members ====================================================

# Affected tier.
[script("pwsh")]
ox-check-llvm-cov: (_ox-check-require "cargo-llvm-cov") (_ox-check-require "cargo-nextest")
    $ErrorActionPreference = 'Stop'
    if ($env:OX_CHECK_INCLUDE_AFFECTED -eq '--skip') {
        Write-Host 'ox-check-llvm-cov: no affected packages; skipping'
        exit 0
    }
    $pkg = @(if ($env:OX_CHECK_INCLUDE_AFFECTED) { -split $env:OX_CHECK_INCLUDE_AFFECTED } else { '--workspace' })
    # cargo-llvm-cov doesn't work on aarch64-pc-windows-msvc: the
    # llvm-profdata that ships with the rust toolchain there fails
    # to merge the .profraw set ("no profile can be merged"). Fall
    # back to plain `cargo nextest run` on that target so we still
    # get test execution; coverage data from this leg wouldn't have
    # been used anyway (coverage upload is gated on Linux only).
    if ($IsWindows -and ($env:PROCESSOR_ARCHITECTURE -eq 'ARM64' -or $env:PROCESSOR_ARCHITEW6432 -eq 'ARM64')) {
        Write-Host 'ox-check-llvm-cov: aarch64-pc-windows-msvc — skipping coverage; running plain nextest'
        & cargo nextest run @pkg --all-features --locked
        exit $LASTEXITCODE
    }
    # cargo llvm-cov writes the .profraw set into target/llvm-cov-target/
    # but the *report* output directory (target/coverage/) is something
    # we choose and must exist before --output-path runs.
    [System.IO.Directory]::CreateDirectory('target/coverage') | Out-Null
    [System.IO.Directory]::CreateDirectory('target/coverage/html') | Out-Null
    # Wipe stale .profraw data so the report reflects only this run.
    cargo llvm-cov clean --workspace --profraw-only
    if ($LASTEXITCODE -ne 0) { exit $LASTEXITCODE }
    # Instrument and run tests; defer report generation so we can emit
    # multiple formats from the same profraw set without re-running.
    & cargo llvm-cov nextest @pkg --all-features --locked --no-report
    if ($LASTEXITCODE -ne 0) { exit $LASTEXITCODE }
    # lcov.info feeds Codecov on GitHub; cobertura.xml feeds
    # PublishCodeCoverageResults@2 on Azure DevOps.
    cargo llvm-cov report --lcov      --output-path target/coverage/lcov.info
    if ($LASTEXITCODE -ne 0) { exit $LASTEXITCODE }
    cargo llvm-cov report --cobertura --output-path target/coverage/cobertura.xml
    if ($LASTEXITCODE -ne 0) { exit $LASTEXITCODE }
    # Local-only HTML viewer (no CI consumer); cheap once the data exists.
    cargo llvm-cov report --html      --output-dir target/coverage/html
    if ($LASTEXITCODE -ne 0) { exit $LASTEXITCODE }

# Affected tier.
[script("pwsh")]
ox-check-doc-test:
    $ErrorActionPreference = 'Stop'
    if ($env:OX_CHECK_INCLUDE_AFFECTED -eq '--skip') {
        Write-Host 'ox-check-doc-test: no affected packages; skipping'
        exit 0
    }
    $pkg = @(if ($env:OX_CHECK_INCLUDE_AFFECTED) { -split $env:OX_CHECK_INCLUDE_AFFECTED } else { '--workspace' })
    & cargo test --doc @pkg --all-features --locked
    if ($LASTEXITCODE -ne 0) { exit $LASTEXITCODE }

# Affected tier.
[script("pwsh")]
ox-check-examples:
    $ErrorActionPreference = 'Stop'
    if ($env:OX_CHECK_INCLUDE_AFFECTED -eq '--skip') {
        Write-Host 'ox-check-examples: no affected packages; skipping'
        exit 0
    }
    $pkg = @(if ($env:OX_CHECK_INCLUDE_AFFECTED) { -split $env:OX_CHECK_INCLUDE_AFFECTED } else { '--workspace' })
    & cargo build @pkg --examples --all-features --locked
    if ($LASTEXITCODE -ne 0) { exit $LASTEXITCODE }

# === pr-mutants members =================================================

# Affected tier. cargo-mutants does its own diff-scoping via --in-diff;
# the affected-tier guard is the wiring-layer's coarse filter (if no
# affected packages exist, the entire mutants run is pointless).
[script("pwsh")]
ox-check-mutants: (_ox-check-require "cargo-mutants")
    $ErrorActionPreference = 'Stop'
    if ($env:OX_CHECK_INCLUDE_AFFECTED -eq '--skip') {
        Write-Host 'ox-check-mutants: no affected packages; skipping'
        exit 0
    }
    # Resolve BASE_REF: env override > origin/main > origin/master.
    $base = $null
    if ($env:BASE_REF) {
        $base = $env:BASE_REF
    } else {
        foreach ($candidate in @('origin/main', 'origin/master')) {
            git rev-parse --verify $candidate 2>$null | Out-Null
            if ($LASTEXITCODE -eq 0) {
                $base = $candidate
                break
            }
        }
    }
    if (-not $base) {
        Write-Error 'ox-check-mutants: no BASE_REF set and neither origin/main nor origin/master is available. Set BASE_REF to the branch to diff against.'
        exit 1
    }
    # cargo-mutants --in-diff takes a FILE path containing a unified
    # diff, not a git revision range. Write the diff to a temp file
    # first. RUNNER_TEMP (GH) and AGENT_TEMPDIRECTORY (ADO) point at
    # the job's scratch dir; fall back to the system temp dir locally.
    $tmp_dir = $env:RUNNER_TEMP
    if (-not $tmp_dir) { $tmp_dir = $env:AGENT_TEMPDIRECTORY }
    if (-not $tmp_dir) { $tmp_dir = [System.IO.Path]::GetTempPath() }
    $diff_path = Join-Path $tmp_dir 'ox-check-mutants.diff'
    git diff "$base..HEAD" --output=$diff_path
    if ($LASTEXITCODE -ne 0) { exit $LASTEXITCODE }
    cargo mutants --in-diff $diff_path --no-shuffle --jobs 0
    if ($LASTEXITCODE -ne 0) { exit $LASTEXITCODE }

# === nightly-runtime members ============================================

# Nightly checks always run full-workspace; impact env vars aren't set
# by the nightly workflow, so the affected-tier default (--workspace)
# applies. Skip guards are still included for local diff-scoped runs.

[script("pwsh")]
ox-check-miri:
    $ErrorActionPreference = 'Stop'
    if ($env:OX_CHECK_INCLUDE_AFFECTED -eq '--skip') {
        Write-Host 'ox-check-miri: no affected packages; skipping'
        exit 0
    }
    $pkg = @(if ($env:OX_CHECK_INCLUDE_AFFECTED) { -split $env:OX_CHECK_INCLUDE_AFFECTED } else { '--workspace' })
    & cargo '+nightly' miri nextest run @pkg
    if ($LASTEXITCODE -ne 0) { exit $LASTEXITCODE }

[script("pwsh")]
ox-check-careful: (_ox-check-require "cargo-careful")
    $ErrorActionPreference = 'Stop'
    if ($env:OX_CHECK_INCLUDE_AFFECTED -eq '--skip') {
        Write-Host 'ox-check-careful: no affected packages; skipping'
        exit 0
    }
    $pkg = @(if ($env:OX_CHECK_INCLUDE_AFFECTED) { -split $env:OX_CHECK_INCLUDE_AFFECTED } else { '--workspace' })
    & cargo '+nightly' careful test @pkg --all-features --locked
    if ($LASTEXITCODE -ne 0) { exit $LASTEXITCODE }

# === nightly-exhaustive members =========================================

# Unscoped. Nightly-exhaustive deliberately runs over the whole
# workspace regardless of diff.
ox-check-mutants-full: (_ox-check-require "cargo-mutants")
    cargo mutants --workspace --no-shuffle --jobs 0

# Required tier. cargo-hack's feature powerset cascades through dep
# features, so the required set (workspace-internal transitive deps)
# is the right scope.
[script("pwsh")]
ox-check-cargo-hack: (_ox-check-require "cargo-hack")
    $ErrorActionPreference = 'Stop'
    if ($env:OX_CHECK_INCLUDE_REQUIRED -eq '--skip') {
        Write-Host 'ox-check-cargo-hack: no required packages; skipping'
        exit 0
    }
    $pkg = @(if ($env:OX_CHECK_INCLUDE_REQUIRED) { -split $env:OX_CHECK_INCLUDE_REQUIRED } else { '--workspace' })
    & cargo hack @pkg --feature-powerset --depth 2 check
    if ($LASTEXITCODE -ne 0) { exit $LASTEXITCODE }

# Affected tier.
[script("pwsh")]
ox-check-bench:
    $ErrorActionPreference = 'Stop'
    if ($env:OX_CHECK_INCLUDE_AFFECTED -eq '--skip') {
        Write-Host 'ox-check-bench: no affected packages; skipping'
        exit 0
    }
    $pkg = @(if ($env:OX_CHECK_INCLUDE_AFFECTED) { -split $env:OX_CHECK_INCLUDE_AFFECTED } else { '--workspace' })
    & cargo bench @pkg --all-features --no-run
    if ($LASTEXITCODE -ne 0) { exit $LASTEXITCODE }

=== justfiles/ox-check/groups.just ===
# Copyright (c) Microsoft Corporation.
# Licensed under the MIT License.
# Owned by cargo-ox-check; edit via `cargo ox-check update`.
# See ../../docs/design/checks.md for the catalog and rationale.

# Each group is one CI job. Within a group, checks run sequentially.

# === PR groups ==========================================================

[group("ox-check")]
ox-check-pr-fast: \
    ox-check-fmt \
    ox-check-clippy \
    ox-check-cargo-sort \
    ox-check-license-headers \
    ox-check-ensure-no-cyclic-deps \
    ox-check-ensure-no-default-features \
    ox-check-doc-build \
    ox-check-readme-check \
    ox-check-spellcheck \
    ox-check-pr-title \
    ox-check-deny \
    ox-check-audit \
    ox-check-udeps \
    ox-check-semver-check \
    ox-check-external-types \
    ox-check-aprz

[group("ox-check")]
ox-check-pr-test: \
    ox-check-llvm-cov \
    ox-check-doc-test \
    ox-check-examples

[group("ox-check")]
ox-check-pr-mutants: ox-check-mutants

# === Nightly groups =====================================================

[group("ox-check")]
ox-check-nightly-test: \
    ox-check-llvm-cov \
    ox-check-doc-test \
    ox-check-examples

[group("ox-check")]
ox-check-nightly-advisories: \
    ox-check-deny \
    ox-check-audit \
    ox-check-aprz \
    ox-check-clippy \
    ox-check-udeps

[group("ox-check")]
ox-check-nightly-runtime: \
    ox-check-miri \
    ox-check-careful

[group("ox-check")]
ox-check-nightly-exhaustive: \
    ox-check-mutants-full \
    ox-check-cargo-hack \
    ox-check-bench

=== justfiles/ox-check/mod.just ===
# Copyright (c) Microsoft Corporation.
# Licensed under the MIT License.
# Owned by cargo-ox-check; edit via `cargo ox-check update`.
# Entry point for the ox-check just recipe tree. The user's root Justfile
# imports this single file; everything else lives in sibling .just files
# pulled in here.

# All multi-statement recipes in this tree use [script("pwsh")]. pwsh
# is preinstalled on Windows (10+), GH/ADO hosted Linux + Windows
# runners, and is installable on macOS/Linux via Homebrew / upstream
# installer. We chose pwsh over bash because:
#
#   - just's shebang dispatch (#!/usr/bin/env bash) requires `cygpath`
#     on Windows, which is only on PATH inside Git Bash. Plain
#     PowerShell can't run shebang recipes.
#   - just's [script("bash")] attribute passes Windows tempfile paths
#     to bash unescaped, and bash interprets the backslashes as escape
#     characters — every recipe fails with a mangled path.
#   - [script("pwsh")] works from plain PowerShell with no PATH
#     augmentation and no path translation. pwsh handles Windows
#     paths natively.
#
# The existing `_ox-check-require pwsh` recipe already established
# pwsh as a tools-floor requirement, so requiring it as the recipe
# interpreter is consistent.
#
# Single-command recipes (e.g. `cargo deny check`) are plain just
# recipes that inherit the adopter's default shell — they're
# shell-agnostic.
#
# IMPORTANT: [script(...)] requires `set unstable`. The adopter's
# root justfile must declare it (typically as a top-level line).
# ox-check's mod.just does NOT redeclare it, to avoid conflicting
# with adopters who already have it.

import 'checks.just'
import 'groups.just'
import 'tiers.just'
import 'tools.just'

# Friendly default: `just ox-check` runs the PR tier.
alias ox-check := ox-check-pr

=== justfiles/ox-check/tiers.just ===
# Copyright (c) Microsoft Corporation.
# Licensed under the MIT License.
# Owned by cargo-ox-check; edit via `cargo ox-check update`.
# See ../../docs/design/checks.md for the tier structure.

# PR tier: every fast check that should run on every pull request.
[group("ox-check")]
ox-check-pr: \
    ox-check-pr-fast \
    ox-check-pr-test \
    ox-check-pr-mutants

# Nightly tier: slow / non-deterministic checks. Runs on a schedule against
# `main`, not on PRs.
[group("ox-check")]
ox-check-nightly: \
    ox-check-nightly-test \
    ox-check-nightly-advisories \
    ox-check-nightly-runtime \
    ox-check-nightly-exhaustive

# Full tier: PR + nightly, end-to-end. Useful before tagging a release.
[group("ox-check")]
ox-check-full: \
    ox-check-pr \
    ox-check-nightly

=== justfiles/ox-check/tool-minimums.txt ===
# Copyright (c) Microsoft Corporation.
# Licensed under the MIT License.
# Owned by cargo-ox-check; edit via `cargo ox-check update`.
#
# Tool-version catalog consumed by `tools.just` recipes
# (_ox-check-require, ox-check-tools-install, ox-check-tools-check).
#
# Format: <cargo-subcommand-binary>=<minimum-version>
# One per line. Lines starting with `#` and blank lines are ignored.
# Versions are SemVer; comparison uses `sort -V` (so "1.2.10" > "1.2.9").
#
# To bump a minimum, edit the version in place. The dirty-file flow
# preserves the edit on subsequent `cargo ox-check update` runs.
# To add a new tool, append a line. To remove a tool, delete its line
# (and any recipe in checks.just that depends on it).
#
# Non-catalog dependencies (rustc, pwsh, just itself) are handled
# directly in tools.just rather than through this file — their
# install/upgrade paths are not cargo-managed.

cargo-aprz=1.0.0
cargo-audit=0.21.0
cargo-careful=0.4.9
cargo-check-external-types=0.4.0
cargo-delta=0.3.1
cargo-deny=0.19.0
cargo-doc2readme=0.6.4
cargo-ensure-no-cyclic-deps=0.2.0
cargo-ensure-no-default-features=1.0.0
cargo-hack=0.6.41
cargo-heather=0.1.0
cargo-llvm-cov=0.8.4
cargo-mutants=26.1.2
cargo-nextest=0.9.122
cargo-semver-checks=0.46.0
cargo-sort=2.0.2
cargo-spellcheck=0.15.1
cargo-udeps=0.1.60

=== justfiles/ox-check/tools.just ===
# Copyright (c) Microsoft Corporation.
# Licensed under the MIT License.
# Owned by cargo-ox-check; edit via `cargo ox-check update`.
# See ../../docs/design/local.md for the policy.

# Public: assert that every catalog tool is present at or above its
# minimum version. Called by `ox-check-tools-check` and as a dependency
# of every check group via individual `_ox-check-require` invocations.
[group("ox-check")]
[script("pwsh")]
ox-check-tools-check:
    $ErrorActionPreference = 'Stop'
    $catalog = 'justfiles/ox-check/tool-minimums.txt'
    $fail = 0
    foreach ($line in Get-Content $catalog) {
        $trimmed = $line.Trim()
        if ($trimmed -eq '' -or $trimmed.StartsWith('#')) { continue }
        if ($trimmed -match '^([^=]+)=') {
            $tool = $Matches[1]
            & just _ox-check-require $tool
            if ($LASTEXITCODE -ne 0) { $fail = 1 }
        }
    }
    & just _ox-check-require rustc
    if ($LASTEXITCODE -ne 0) { $fail = 1 }
    exit $fail

# Public: install (or upgrade) every catalog tool to its minimum
# version. Idempotent — ``cargo install --locked`` is a no-op when
# the installed version already satisfies the requirement.
#
# `installer` selects the install backend:
#   - "install"  (default): ``cargo install --locked`` — pure-source
#     builds; works in any cargo environment, no extra runtime
#     dependencies. Slow (~30 minutes for the full catalog on a cold
#     runner). Used by ADO, where ``cargo-binstall`` has known
#     compliance issues for internal pipelines.
#   - "binstall": ``cargo binstall --no-confirm --locked`` — downloads
#     a pre-built binary from each tool's GitHub Releases when
#     available, falling back to ``cargo install`` per-tool when
#     not. Cuts catalog install time from ~30 min to ~1 min on a
#     cold runner. Requires ``cargo-binstall`` to be installed
#     beforehand. Used by the GitHub Actions setup action.
#
# Per-tool failures don't abort the whole install — a tool that
# doesn't build on the current host (e.g. cargo-mutants on
# aarch64-pc-windows-msvc, where the upstream winapi dep doesn't
# compile) shouldn't block other tools. Each failure is reported
# at the end; recipes that use the missing tool will get a clean
# error from ``_ox-check-require`` at recipe-run time. The recipe
# itself exits non-zero only if at least one install failed, so
# CI surfaces the problem.
[group("ox-check")]
[script("pwsh")]
ox-check-tools-install installer="install":
    $ErrorActionPreference = 'Continue'
    $installer = '{{installer}}'
    if ($installer -ne 'install' -and $installer -ne 'binstall') {
        Write-Error "ox-check-tools-install: unknown installer '$installer' (expected 'install' or 'binstall')"
        exit 2
    }
    $catalog = 'justfiles/ox-check/tool-minimums.txt'
    $failed = [System.Collections.Generic.List[string]]::new()
    foreach ($line in Get-Content $catalog) {
        $trimmed = $line.Trim()
        if ($trimmed -eq '' -or $trimmed.StartsWith('#')) { continue }
        if ($trimmed -match '^([^=]+)=(.+)$') {
            $tool = $Matches[1]
            $min = $Matches[2]
            # Skip if the tool is already installed at or above the
            # required version. This is what makes the actions/cache
            # restore actually useful — without the early-exit, every
            # post-restore run would try to re-install on top of the
            # cached binaries and fail with "binary already exists in
            # destination". The `2>$null` swallows the help-text noise
            # _ox-check-require emits when the tool is missing.
            & just _ox-check-require $tool 2>$null
            if ($LASTEXITCODE -eq 0) {
                Write-Host "ox-check-tools-install ($installer): $tool >= $min (already satisfied)"
                continue
            }
            Write-Host "ox-check-tools-install ($installer): $tool >= $min"
            $installed = $false
            if ($installer -eq 'binstall') {
                cargo binstall --no-confirm --locked $tool --version ">=$min"
                if ($LASTEXITCODE -eq 0) {
                    $installed = $true
                } else {
                    Write-Host "  binstall failed for $tool; falling back to cargo install" -ForegroundColor Yellow
                    cargo install --locked $tool --version ">=$min"
                    if ($LASTEXITCODE -eq 0) { $installed = $true }
                }
            } else {
                cargo install --locked $tool --version ">=$min"
                if ($LASTEXITCODE -eq 0) { $installed = $true }
            }
            if (-not $installed) {
                Write-Host "ox-check-tools-install: $tool install FAILED (continuing)" -ForegroundColor Yellow
                $failed.Add($tool)
            }
        }
    }
    if ($failed.Count -gt 0) {
        Write-Host ""
        Write-Host "ox-check-tools-install: $($failed.Count) tool(s) failed to install:" -ForegroundColor Yellow
        foreach ($t in $failed) { Write-Host "  - $t" -ForegroundColor Yellow }
        Write-Host "Recipes that depend on these tools will fail at run time via _ox-check-require." -ForegroundColor Yellow
        exit 1
    }

# Internal: assert that `name` meets its catalog minimum (or, for tools
# not in the catalog, that it's at least present). Three lookup paths:
#
#   - "rustc": presence-only; the workspace's rust-toolchain.toml drives
#     the actual version requirement (rustup auto-installs).
#   - "pwsh": presence-only with a per-OS install hint.
#   - Anything else: looked up in tool-minimums.txt; if present, the
#     installed version is parsed from `cargo install --list` and
#     compared via the [version] type. If not in the catalog,
#     presence-only fallback (covers system binaries like `just`
#     itself, `git`).
[script("pwsh")]
_ox-check-require name:
    $ErrorActionPreference = 'Stop'
    $name = '{{name}}'
    $catalog = 'justfiles/ox-check/tool-minimums.txt'

    switch ($name) {
        'rustc' {
            if (-not (Get-Command rustc -ErrorAction SilentlyContinue)) {
                Write-Error 'ox-check: rustc not found. Install via rustup: https://rustup.rs'
                exit 1
            }
            exit 0
        }
        'pwsh' {
            if (-not (Get-Command pwsh -ErrorAction SilentlyContinue)) {
                $hint = if ($IsMacOS) {
                    'brew install --cask powershell'
                } elseif ($IsLinux) {
                    'see https://github.com/PowerShell/PowerShell'
                } else {
                    'winget install --id Microsoft.PowerShell'
                }
                Write-Error "ox-check: pwsh (PowerShell Core) not found. Install: $hint"
                exit 1
            }
            exit 0
        }
    }

    # Catalog lookup. Trim CRLF (Windows checkouts) and skip
    # comments / blank lines while we're at it.
    $spec = $null
    if (Test-Path $catalog) {
        foreach ($line in Get-Content $catalog) {
            $trimmed = $line.Trim()
            if ($trimmed -eq '' -or $trimmed.StartsWith('#')) { continue }
            $pattern = '^' + [regex]::Escape($name) + '=(.+)$'
            if ($trimmed -match $pattern) {
                $spec = $Matches[1]
                break
            }
        }
    }

    if (-not $spec) {
        # Not in catalog: presence-only fallback for tools we don't
        # version-gate (`just` itself, `git`, system binaries).
        if (-not (Get-Command $name -ErrorAction SilentlyContinue)) {
            Write-Error "ox-check: required tool '$name' not found. Install hint: cargo install --locked $name"
            exit 1
        }
        exit 0
    }

    $min = $spec
    # Parse `cargo install --list` for installed version. Lines look like:
    #   cargo-deny v0.18.5:
    #       cargo-deny
    $installed = $null
    $listPattern = '^' + [regex]::Escape($name) + ' v(\S+):'
    foreach ($line in (cargo install --list 2>$null)) {
        if ($line -match $listPattern) {
            $installed = $Matches[1]
            break
        }
    }

    if (-not $installed) {
        Write-Error "ox-check: '$name' not installed (need >=v$min). Install: cargo install --locked $name --version '>=$min'"
        exit 1
    }

    # SemVer comparison via the [version] type. Strip any pre-release
    # / build-metadata suffix (e.g. "1.2.3-alpha.4") for parsing —
    # [version] only handles dotted numeric components.
    $minClean = ($min -split '[-+]', 2)[0]
    $instClean = ($installed -split '[-+]', 2)[0]
    $minV = [version]$minClean
    $instV = [version]$instClean
    if ($instV -lt $minV) {
        Write-Error "ox-check: '$name' is at v$installed; need >=v$min. Upgrade: cargo install --locked $name --version '>=$min'"
        exit 1
    }

=== rustfmt.toml ===
# >>> ox-check-managed: ox-check-rustfmt
edition = "2024"
max_width = 140
newline_style = "Unix"
use_field_init_shorthand = true
use_try_shorthand = true
# <<< ox-check-managed: ox-check-rustfmt
